# Supabase (.env.local 에만 넣고 커밋하지 마세요)
# 대시보드: https://supabase.com/dashboard → Project Settings → API
#
# 반드시 필요: service_role 키 (절대 NEXT_PUBLIC_ 붙이지 말 것)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
#
# 프로젝트 URL — 아래 둘 중 하나만 있으면 됩니다.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# 또는 클라이언트용으로 이미 쓰는 경우:
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
